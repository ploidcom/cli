{
  "name": "@ploid/cli",
  "version": "0.1.0",
  "description": "Command-line client for the Ploid Public API.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://ploid.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ploid/ploid-cli.git"
  },
  "keywords": [
    "ploid",
    "cli",
    "people",
    "enrichment",
    "linkedin",
    "api"
  ],
  "bin": {
    "ploid": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
